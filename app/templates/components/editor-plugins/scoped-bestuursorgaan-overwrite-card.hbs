<div class="modal-dialog__header u-border--lighter--bottom u-padding--round--tiny">
  <div class="grid">
    <div class="col--10-12">
    	{{info.label}}
    </div>
    <div class="col--2-12 u-align-right">
    	<i class="fa fa-angle-down"></i>
    </div>
{{!--     <div class="col--2-12 u-align-right">
      <a class="link--icon--close" href="#">
        <span class="u-visually-hidden">Venster sluiten</span>
      </a>
    </div> --}}
  </div>
</div>

<div class="modal-dialog__content modal-dialog__content--sectioned">
  {{#if getBestuursorganen.isRunning}}
    <div class="u-padding--round">
      <p class="loader"><span class="u-visually-hidden">Aan het laden</span></p>
    </div>
  {{else if bestuursorganenInTijd.length}}
    <ul class="link-list link-list--bordered">
      {{#each bestuursorganenInTijd as |b| }}

        <li class="link-list__item link-list__item--sidenotes">
          <a class="" onclick={{action 'refer' b}}>
            <p class="small">{{b.isTijdsspecialisatieVan.naam}}</p>

            <p class="link-list__item__sidenote smallest">
              {{#if b.bindingEinde}}
                {{moment-format b.bindingStart 'DD/MM/YYYY'}} - {{moment-format b.bindingEinde 'DD/MM/YYYY'}}
              {{else}}
                Vanaf {{moment-format b.bindingStart 'DD/MM/YYYY'}}
              {{/if}}
            </p>
          </a>
        </li>
      {{/each}}
    </ul>
  {{else}}
    <div class="u-padding--round--small">
      <p>Geen besturen gevonden. Vernieuw deze pagina, of kijk of uw internetconnectie in orde is.</p>
      <br>
      <p>Moest dit probleem aanhouden, neem contact op met <a href="mailto:Gelinkt-Notuleren@vlaanderen.be">Gelinkt-Notuleren@vlaanderen.be</a>.</p>
    </div>
  {{/if}}
</div>

