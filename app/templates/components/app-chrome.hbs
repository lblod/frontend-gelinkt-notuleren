<div class="grid u-spacer--tiny">
  <div class="col--6-12">
    {{#link-to 'inbox.index' class="smaller link-dark"}}&leftarrow; Terug naar overzicht notulen{{/link-to}}
    <label class="pill u-spacer--left--tiny">
      <span>{{get (await currentSession.group) 'classificatie.label'}} {{get (await currentSession.group) 'naam'}}</span>
    </label>
  </div>
  <div class="col--6-12 u-align-right">
    <p class="smaller">
	    {{#if startSyncModal}}
	      {{#wu-link-button isSmall=true isLink=true onClick=startSyncModal}}
	        <i class="fa fa-rotate-right"></i> Synchroniseer gegevens met OCMW
	      {{/wu-link-button}}
	    {{/if}}

	    {{#if editorDocument.isNew}}
	      <label class="pill pill--primary-yellow">
	        <span class="badge badge--accent badge--xs badge--initials"><i class="vi vi-warning"></i></span>
	        <span>Concept niet bewaard</span>
	      </label>
	    {{else}}
	      {{#if editorDocument.updatedOn}}
	        Bewaard {{moment-calendar editorDocument.updatedOn}}
	        {{editor-status-pill status=(await documentContainer.status)}}
	      {{else}}
	        <span class="smaller u-padding--right--tiny">
	          <span class="badge badge--accent badge--xs badge--initials"><i class="vi vi-warning"></i></span>
	          <span>Wijzigingen niet bewaard</span>
	        </span>
	        {{editor-status-pill status=(await documentContainer.status)}}
	      {{/if}}
	    {{/if}}
	  </p>
  </div>
</div>
<div class="grid">
  <div class="col--6-12">
    {{editor-document-title editorDocument=editorDocument readOnly=readOnly}}
  </div>
  <div class="col--6-12 u-align-right">

    {{#wu-button-group class="u-align-right"}}
      {{#if editorDocument.isNew}}
        {{#link-to 'inbox.index' class="button button--small button--narrow button--link button--link--dark"}}Verwijder concept{{/link-to}}
      {{else}}
        {{wu-button label="Naar prullenmand" isSmall=true isNarrow=true isLink=true isDarkLink=true onClick=sendToTrash}}
      {{/if}}
      {{wu-button label="Ondertekenen en publiceren" isSmall=true isNarrow=true isAlt=true onClick=publish}}
      {{wu-button label="Bewaar concept" isNarrow=true isSmall=true onClick=save}}
    {{/wu-button-group}}

  </div>
</div>
