<LinkTo
  @route={{if
    (or (eq this.editorStatus 'published') @readOnly)
    'agendapoints.show'
    'agendapoints.edit'
  }}
  @model={{@documentContainer.id}}
  class='au-c-link'
>
  {{#if @documentContainer.currentVersion.title}}
    {{limit-content @documentContainer.currentVersion.title 70}}
  {{else}}
    &lt;{{t 'agendapoint.no-title'}}&gt;
  {{/if}}
</LinkTo>